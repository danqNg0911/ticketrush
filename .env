# ====================== DATABASE ======================
POSTGRES_DB=ticketrush_db
POSTGRES_USER=ticketrush_user
POSTGRES_PASSWORD=123
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ====================== BACKEND ======================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://ticketrush_user:123@postgres:5432/ticketrush_db

# Security - JWT
SECRET_KEY=magento
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ====================== REDIS ======================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ====================== FRONTEND ======================
VITE_API_BASE_URL=http://localhost:8000/api
VITE_WS_BASE_URL=ws://localhost:8000/ws
VITE_APP_NAME=TicketRush
VITE_APP_VERSION=1.0.0

# ====================== ENVIRONMENT ======================
ENVIRONMENT=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
